<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>오늘의 나 돌아보기</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f5f1;
        --surface: #ffffff;
        --text: #1f2227;
        --muted: #6a707c;
        --accent: #2b7a78;
        --accent-soft: #e6f2f1;
        --border: #e3e0da;
        --shadow: 0 16px 36px rgba(30, 31, 35, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      .wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 20px 60px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      header a {
        text-decoration: none;
        color: var(--accent);
        font-weight: 600;
      }

      .card {
        margin-top: 24px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--shadow);
      }

      .question {
        margin-bottom: 18px;
      }

      .question label {
        display: block;
        font-weight: 700;
        margin-bottom: 8px;
      }

      .question input[type="text"],
      .question textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 10px 12px;
        font-size: 14px;
        font-family: inherit;
      }

      textarea {
        resize: vertical;
        min-height: 80px;
      }

      .mood {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .mood label {
        background: var(--accent-soft);
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        cursor: pointer;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      button {
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        background: var(--accent);
        color: #fff;
        font-weight: 700;
        cursor: pointer;
      }

      button.secondary {
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--accent);
      }

      .result {
        margin-top: 20px;
        background: var(--accent-soft);
        border-radius: 16px;
        padding: 16px;
        color: #2a3f3e;
        font-size: 14px;
        line-height: 1.6;
      }

      .note {
        margin-top: 12px;
        color: var(--muted);
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <h1>오늘의 나 돌아보기</h1>
        <a href="index.html">홈으로</a>
      </header>

      <div class="card">
        <div class="question">
          <label>오늘 내 에너지는 어느 정도인가요?</label>
          <div class="mood">
            <label><input type="radio" name="energy" value="낮음" /> 낮음</label>
            <label><input type="radio" name="energy" value="보통" /> 보통</label>
            <label><input type="radio" name="energy" value="좋음" /> 좋음</label>
          </div>
        </div>

        <div class="question">
          <label>지금 가장 많이 느끼는 감정은?</label>
          <input type="text" id="emotion" placeholder="예: 평온함, 피로, 설렘" />
        </div>

        <div class="question">
          <label>오늘 나를 지켜준 작은 행동은?</label>
          <input type="text" id="action" placeholder="예: 점심 산책, 따뜻한 물 한 잔" />
        </div>

        <div class="question">
          <label>지금 나에게 필요한 한 가지는?</label>
          <textarea id="need" placeholder="예: 집중, 휴식, 정리, 대화"></textarea>
        </div>

        <div class="actions">
          <button id="createBtn">요약 만들기</button>
          <button id="resetBtn" class="secondary">초기화</button>
        </div>

        <div class="result" id="resultBox" style="display: none;"></div>
        <div class="note">
          이 콘텐츠는 웰니스 목적이며, 기록은 저장되지 않습니다.
        </div>
      </div>
    </div>

    <script>
      const createBtn = document.getElementById("createBtn");
      const resetBtn = document.getElementById("resetBtn");
      const resultBox = document.getElementById("resultBox");

      function getSelectedValue(name) {
        const input = document.querySelector(`input[name="${name}"]:checked`);
        return input ? input.value : "알 수 없음";
      }

      createBtn.addEventListener("click", () => {
        const energy = getSelectedValue("energy");
        const emotion = document.getElementById("emotion").value || "정리되지 않은 감정";
        const action = document.getElementById("action").value || "작은 루틴";
        const need = document.getElementById("need").value || "잠깐의 여유";

        resultBox.innerHTML = `
          <strong>오늘의 요약</strong><br />
          에너지: ${energy}<br />
          감정: ${emotion}<br />
          나를 지켜준 행동: ${action}<br />
          필요한 것: ${need}<br /><br />
          작은 제안: 오늘은 ${need}을(를) 위해 5분만 시간을 확보해보세요.
        `;
        resultBox.style.display = "block";
      });

      resetBtn.addEventListener("click", () => {
        document.querySelectorAll('input[name="energy"]').forEach((input) => {
          input.checked = false;
        });
        document.getElementById("emotion").value = "";
        document.getElementById("action").value = "";
        document.getElementById("need").value = "";
        resultBox.style.display = "none";
      });
    </script>
  </body>
</html>
